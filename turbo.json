{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "migration:generate": {
      "dependsOn": ["build"],
      "cache": false
    },
    "migration:run": {
      "cache": false
    },
    "migration:revert": {
      "cache": false
    },
    "migration:show": {
      "cache": false
    }
  }
}
